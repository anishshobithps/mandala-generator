{
  "functions": {
    "api/og.tsx": {
      "memory": 1024,
      "includeFiles": "node_modules/@takumi-rs/core-linux-x64-gnu/**,node_modules/@takumi-rs/core-linux-x64-musl/**,node_modules/@takumi-rs/core-linux-arm64-gnu/**,node_modules/@takumi-rs/core-linux-arm64-musl/**"
    },
    "api/index.ts": {
      "memory": 256
    }
  },
  "routes": [
    {
      "src": "/stats/script.js",
      "dest": "https://cloud.umami.is/script.js"
    },
    {
      "src": "/api/send",
      "dest": "https://cloud.umami.is/api/send"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "^/$",
      "dest": "/api/index"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
